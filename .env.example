# Hermes MCP Bridge — Environment Configuration
# ==============================================
# Copy this file to .env and fill in the values.
#
# On target machines, the deploy script copies this to
# ${MCP_BRIDGE_DIR}/.env (default: /opt/hermes-mcp-bridge/.env).

# ── REQUIRED ────────────────────────────────────────────────────────────────
# Bearer token for every API request.
# Generate one: openssl rand -hex 32
MCP_BRIDGE_TOKEN=change-me-to-a-random-hex-token

# ── NETWORK ─────────────────────────────────────────────────────────────────
# IP address to bind to. Set to this machine's WireGuard IP
# (e.g. 10.0.0.X) or 0.0.0.0 for all interfaces.
# Default: 127.0.0.1 (local only — change for remote access!)
MCP_BRIDGE_HOST=127.0.0.1

# HTTP port to listen on (default: 8000)
MCP_BRIDGE_PORT=8000

# ── SECURITY ────────────────────────────────────────────────────────────────
# Comma-separated list of allowed binaries for execute_command.
# Only commands whose first token matches one of these are allowed.
# Use fnmatch globs, e.g. "docker*" matches docker-compose too.
MCP_EXECUTE_ALLOWLIST=docker,systemctl,journalctl,df,free,ls,cat,grep,ps,top,htop,who,uptime,uname,id,pwd,echo,date

# ── TIMEOUT ─────────────────────────────────────────────────────────────────
# Default timeout in seconds for tool commands (default: 30)
MCP_TOOL_TIMEOUT=30
